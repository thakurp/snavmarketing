---
const navLinks = [
  { label: 'Services', href: '/services' },
  { label: 'Industries', href: '/industries/tradies' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<div class="nav-wrapper" id="nav-wrapper">
  <header class="nav-pill" id="nav-pill">
    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="SNAV Marketing Home">
      <span class="logo-sn">SN</span><span class="logo-av">AV</span>
    </a>

    <!-- Desktop nav links -->
    <nav class="desktop-nav" aria-label="Main navigation">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath.startsWith(link.href) && link.href !== '/' }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="nav-actions">
      <!-- Theme toggle -->
      <button class="theme-btn" id="theme-toggle" aria-label="Toggle theme">
        <!-- Moon icon (visible in light mode — click to go dark) -->
        <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <!-- Sun icon (visible in dark mode — click to go light) -->
        <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>

      <a href="/contact" class="nav-cta">Get Free Quote</a>

      <!-- Mobile hamburger -->
      <button class="hamburger" id="hamburger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <!-- Mobile menu (drops below pill) -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    {navLinks.map(link => (
      <a href={link.href} class="mobile-nav-link">{link.label}</a>
    ))}
    <a href="/contact" class="btn-primary mobile-cta">Get Free Quote</a>
  </div>
</div>

<style>
  .nav-wrapper {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    padding: 14px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }

  .nav-pill {
    pointer-events: all;
    width: 100%;
    max-width: 980px;
    background: var(--nav-bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--nav-border);
    border-radius: var(--r-pill, 999px);
    display: flex;
    align-items: center;
    padding: 6px 8px 6px 22px;
    gap: 4px;
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  .nav-pill.scrolled {
    background: var(--nav-bg);
    box-shadow: 0 8px 32px rgba(0,0,0,0.35);
  }
  [data-theme="light"] .nav-pill.scrolled {
    box-shadow: 0 4px 24px rgba(30,58,95,0.12);
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
    flex-shrink: 0;
    margin-right: 0.5rem;
  }
  .logo-sn {
    font-size: 1.375rem;
    font-weight: 900;
    color: var(--text-heading);
    letter-spacing: -0.03em;
    font-family: 'Syne', sans-serif;
  }
  .logo-av {
    font-size: 1.375rem;
    font-weight: 900;
    color: var(--accent);
    letter-spacing: -0.03em;
    font-family: 'Syne', sans-serif;
  }

  /* Desktop nav */
  .desktop-nav {
    display: none;
    align-items: center;
    gap: 2px;
    flex: 1;
  }
  @media (min-width: 768px) { .desktop-nav { display: flex; } }

  .nav-link {
    padding: 0.45rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-body);
    border-radius: var(--r-pill, 999px);
    transition: color 0.15s, background 0.15s;
    letter-spacing: -0.01em;
  }
  .nav-link:hover, .nav-link.active {
    color: var(--text-heading);
    background: var(--border);
  }
  .nav-link.active { font-weight: 600; }

  /* Actions */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-left: auto;
  }

  /* Theme button */
  .theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px; height: 36px;
    border-radius: var(--r-pill, 999px);
    background: var(--border);
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .theme-btn:hover { color: var(--accent); background: var(--surface-2); }

  /* Icon visibility based on theme */
  .icon-sun { display: block; }
  .icon-moon { display: none; }
  [data-theme="light"] .icon-sun { display: none; }
  [data-theme="light"] .icon-moon { display: block; }

  /* CTA */
  .nav-cta {
    display: none;
    padding: 0.5rem 1.125rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    background: var(--accent);
    border-radius: var(--r-pill, 999px);
    letter-spacing: -0.01em;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .nav-cta:hover { background: var(--accent-dark); transform: translateY(-1px); }
  @media (min-width: 768px) { .nav-cta { display: flex; align-items: center; } }

  /* Hamburger */
  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 28px; height: 18px;
    background: none; border: none; cursor: pointer; padding: 0;
  }
  .hamburger span {
    display: block; height: 2px;
    background: var(--text-heading);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
  @media (min-width: 768px) { .hamburger { display: none; } }

  /* Mobile menu */
  .mobile-menu {
    pointer-events: all;
    display: none;
    margin-top: 8px;
    width: 100%;
    max-width: 980px;
    background: var(--nav-bg);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border: 1px solid var(--nav-border);
    border-radius: 1.5rem;
    padding: 1rem 1.25rem 1.25rem;
    transition: background 0.3s;
  }
  .mobile-menu.open { display: flex; flex-direction: column; gap: 4px; }
  @media (min-width: 768px) { .mobile-menu { display: none !important; } }

  .mobile-nav-link {
    display: block;
    padding: 0.65rem 0.75rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-body);
    border-radius: 0.625rem;
    transition: background 0.15s, color 0.15s;
  }
  .mobile-nav-link:hover { background: var(--border); color: var(--text-heading); }
  .mobile-cta {
    margin-top: 0.5rem;
    text-align: center;
    padding: 0.75rem;
    font-size: 0.9375rem;
    border-radius: 0.75rem;
  }
</style>

<script>
  // Hamburger toggle
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    hamburger.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Scroll: add .scrolled to pill
  const navPill = document.getElementById('nav-pill');
  window.addEventListener('scroll', () => {
    navPill?.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') ?? 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('snav-theme', next);
  });
</script>


