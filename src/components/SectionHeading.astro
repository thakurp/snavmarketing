---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
}

const { title, subtitle, centered = true, light = false } = Astro.props;
---

<div class:list={['section-heading', { 'centered': centered }]}>
  <h2 class:list={['heading-title', { 'light': light }]}>{title}</h2>
  {subtitle && <p class:list={['heading-subtitle', { 'light': light }]}>{subtitle}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: 3rem;
  }

  .centered {
    text-align: center;
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
    margin-bottom: 3rem;
  }

  .heading-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.75rem;
    line-height: 1.15;
  }

  .heading-title.light {
    color: white;
  }

  .heading-subtitle {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .heading-subtitle.light {
    color: rgba(238,242,255,0.65);
  }
</style>
