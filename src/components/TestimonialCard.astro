---
interface Props {
  quote: string;
  name: string;
  business: string;
  industry: string;
  initials: string;
}

const { quote, name, business, industry, initials } = Astro.props;
---

<div class="testimonial-card card">
  <div class="stars" aria-label="5 stars">★★★★★</div>
  <blockquote class="quote">"{quote}"</blockquote>
  <div class="author">
    <div class="avatar" aria-hidden="true">{initials}</div>
    <div>
      <p class="author-name">{name}</p>
      <p class="author-business">{business} · {industry}</p>
    </div>
  </div>
</div>

<style>
  .testimonial-card {
    padding: 2rem;
    background: var(--surface-card);
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .stars {
    color: #FFB800;
    font-size: 1.125rem;
    letter-spacing: 0.05em;
  }

  .quote {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--text-body);
    font-style: italic;
    flex: 1;
  }

  .author {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-top: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .avatar {
    width: 44px;
    height: 44px;
    border-radius: 9999px;
    background: linear-gradient(135deg, var(--accent), #818CF8);
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-heading);
  }

  .author-business {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }
</style>
