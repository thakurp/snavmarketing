---
const services = [
  { label: 'Digital Advertising', href: '/services/digital-advertising' },
  { label: 'Social Media Marketing', href: '/services/social-media-marketing' },
  { label: 'Website Creation', href: '/services/website-creation' },
  { label: 'Website Optimisation', href: '/services/website-optimisation' },
  { label: 'App Development', href: '/services/app-development' },
  { label: 'Lead Generation', href: '/services/lead-generation' },
];

const industries = [
  { label: 'Tradies', href: '/industries/tradies' },
  { label: 'Barber Shops', href: '/industries/barber-shops' },
  { label: 'Restaurants', href: '/industries/restaurants' },
  { label: 'Small Business', href: '/industries/small-business' },
];

const company = [
  { label: 'About Us', href: '/about' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="footer">
  <!-- Gradient orb decoration -->
  <div class="footer-orb footer-orb-1" aria-hidden="true"></div>
  <div class="footer-orb footer-orb-2" aria-hidden="true"></div>

  <div class="container-lg footer-inner">
    <!-- Brand col -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="SNAV Marketing">
        <span class="logo-sn">SN</span><span class="logo-av">AV</span>
      </a>
      <p class="footer-tagline">Sydney's results-first digital marketing agency.<br/>More customers. Less headache.</p>
      <div class="footer-contact">
        <a href="mailto:hello@snavmarketing.com.au" class="contact-row">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          hello@snavmarketing.com.au
        </a>
        <a href="tel:+61291234567" class="contact-row">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.59 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.29 6.29l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          +61 2 9123 4567
        </a>
        <span class="contact-row">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          Sydney, NSW, Australia
        </span>
      </div>
    </div>

    <!-- Services -->
    <div class="footer-col">
      <h3 class="footer-heading">Services</h3>
      <ul>
        {services.map(s => <li><a href={s.href} class="footer-link">{s.label}</a></li>)}
      </ul>
    </div>

    <!-- Industries + Company -->
    <div class="footer-col">
      <h3 class="footer-heading">Industries</h3>
      <ul>
        {industries.map(i => <li><a href={i.href} class="footer-link">{i.label}</a></li>)}
      </ul>
      <h3 class="footer-heading" style="margin-top:1.5rem">Company</h3>
      <ul>
        {company.map(c => <li><a href={c.href} class="footer-link">{c.label}</a></li>)}
      </ul>
    </div>

    <!-- CTA -->
    <div class="footer-col">
      <div class="footer-cta-card">
        <p class="cta-label">Ready to grow?</p>
        <p class="cta-text">Get a free digital audit and see exactly how we'll win you more customers in Sydney.</p>
        <a href="/contact" class="footer-cta-btn">Get Free Audit →</a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="container-lg footer-bottom-inner">
      <span>&copy; {new Date().getFullYear()} SNAV Marketing Pty Ltd. All rights reserved.</span>
      <span class="made-in">Made in Sydney 🇦🇺</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    background: #030712;
    border-top: 1px solid var(--border);
    padding-top: 5rem;
  }

  /* Aurora orbs */
  .footer-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }
  .footer-orb-1 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(255,107,53,0.1) 0%, transparent 70%);
    top: -80px; right: -60px;
  }
  .footer-orb-2 {
    width: 350px; height: 350px;
    background: radial-gradient(circle, rgba(129,140,248,0.08) 0%, transparent 70%);
    bottom: 0; left: -60px;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-bottom: 4rem;
    position: relative;
    z-index: 1;
  }
  @media (min-width: 640px)  { .footer-inner { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .footer-inner { grid-template-columns: 2fr 1fr 1fr 1.5fr; } }

  /* Brand */
  .footer-logo {
    display: inline-flex;
    align-items: baseline;
    text-decoration: none;
    margin-bottom: 1rem;
    gap: 0;
  }
  .logo-sn {
    font-family: 'Syne', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: #EEF2FF;
    letter-spacing: -0.03em;
  }
  .logo-av {
    font-family: 'Syne', sans-serif;
    font-size: 1.75rem;
    font-weight: 800;
    color: #FF6B35;
    letter-spacing: -0.03em;
  }
  .footer-tagline {
    font-size: 0.9rem;
    line-height: 1.65;
    color: rgba(238,242,255,0.45);
    margin-bottom: 1.25rem;
  }
  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .contact-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: rgba(238,242,255,0.45);
    text-decoration: none;
    transition: color 0.15s;
  }
  .contact-row:hover { color: #FF6B35; }

  /* Col headings */
  .footer-heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(238,242,255,0.35);
    margin-bottom: 0.875rem;
  }
  .footer-col ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.375rem;
  }
  .footer-link {
    font-size: 0.9rem;
    color: rgba(238,242,255,0.5);
    text-decoration: none;
    transition: color 0.15s;
    display: inline-block;
    padding: 0.1rem 0;
  }
  .footer-link:hover { color: #FF6B35; }

  /* CTA card */
  .footer-cta-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 1rem;
    padding: 1.5rem;
  }
  .cta-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #FF6B35;
    margin-bottom: 0.625rem;
  }
  .cta-text {
    font-size: 0.9rem;
    line-height: 1.65;
    color: rgba(238,242,255,0.5);
    margin-bottom: 1.25rem;
  }
  .footer-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.625rem 1.25rem;
    background: #FF6B35;
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    letter-spacing: -0.01em;
  }
  .footer-cta-btn:hover { background: #e55a24; transform: translateY(-1px); }

  /* Bottom bar */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 1.25rem 0;
    position: relative;
    z-index: 1;
  }
  .footer-bottom-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: rgba(238,242,255,0.3);
  }
  .made-in { letter-spacing: 0.01em; }
</style>

