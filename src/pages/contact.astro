---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Contact SNAV Marketing &#8212; Get a Free Digital Strategy Audit"
  description="Get in touch with SNAV Marketing in Sydney. Book a free 30-minute strategy call or send us a message. We'll respond within 1 business day."
  canonical="/contact"
>
  <!-- Hero -->
  <section class="contact-hero">
    <div class="container-lg">
      <p class="eyebrow">Get in Touch</p>
      <h1 class="hero-title">Let's Talk About Growing<br />Your Business.</h1>
      <p class="hero-sub">Book a free 30-minute strategy call or send us a message. We'll review your current online presence and come back to you with honest, actionable advice &#8212; no obligation.</p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="section-pad">
    <div class="container-lg contact-grid">
      <!-- Contact Info -->
      <div class="contact-info">
        <h2 class="h2">Contact Details</h2>

        <div class="info-item">
          <span class="info-icon">📍</span>
          <div>
            <p class="info-label">Location</p>
            <p class="info-value">Sydney, NSW, Australia</p>
            <p class="info-sub">Serving Sydney metro and surrounds</p>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">📧</span>
          <div>
            <p class="info-label">Email</p>
            <a href="mailto:hello@snavmarketing.com.au" class="info-link">hello@snavmarketing.com.au</a>
            <p class="info-sub">We reply within 1 business day</p>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">📞</span>
          <div>
            <p class="info-label">Phone</p>
            <a href="tel:+61291234567" class="info-link">+61 2 9123 4567</a>
            <p class="info-sub">Mon&#8211;Fri, 9am&#8211;6pm AEST</p>
          </div>
        </div>

        <div class="info-item">
          <span class="info-icon">💬</span>
          <div>
            <p class="info-label">Response Time</p>
            <p class="info-value">Within 1 business day</p>
            <p class="info-sub">Often much faster</p>
          </div>
        </div>

        <div class="social-section">
          <p class="social-label">Follow Us</p>
          <div class="social-links">
            <a href="https://instagram.com/snavmarketing" class="social-link" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              Instagram
            </a>
            <a href="https://facebook.com/snavmarketing" class="social-link" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
            <a href="https://linkedin.com/company/snavmarketing" class="social-link" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              LinkedIn
            </a>
          </div>
        </div>

        <div class="booking-card">
          <h3 class="booking-h3">Prefer to Book Directly?</h3>
          <p class="booking-p">Use the form opposite or email us to book your free 30-minute strategy call. We'll come prepared with insights about your current online presence.</p>
          <a href="mailto:hello@snavmarketing.com.au?subject=Book%20Free%20Strategy%20Call" class="btn-outline">Email to Book a Call</a>
        </div>
      </div>

      <!-- Form -->
      <div class="contact-form-wrap">
        <h2 class="h2">Send Us a Message</h2>
        <p class="form-sub">Fill in the form and we'll be back to you within 1 business day with a tailored response.</p>
        <ContactForm />
      </div>
    </div>
  </section>

  <!-- Service Quick Links -->
  <section class="section-pad" style="background: var(--bg-alt);">
    <div class="container-lg">
      <h2 class="h2 text-center">Not Sure What You Need?</h2>
      <p class="center-sub">Browse our services and industries pages, or just tell us your goal in the form above and we'll work out the best approach together.</p>
      <div class="quick-links">
        <a href="/services/digital-advertising" class="quick-link">?? Digital Advertising</a>
        <a href="/services/social-media-marketing" class="quick-link">?? Social Media Marketing</a>
        <a href="/services/website-creation" class="quick-link">?? Website Creation</a>
        <a href="/services/website-optimisation" class="quick-link">? Website Optimisation</a>
        <a href="/services/app-development" class="quick-link">?? App Development</a>
        <a href="/services/lead-generation" class="quick-link">?? Lead Generation</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero { background: linear-gradient(135deg, #1E3A5F 0%, #152b47 100%); padding: calc(5rem + 80px) 0; text-align: center; }
  .eyebrow { font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #FF6B35; margin-bottom: 1rem; }
  .hero-title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; color: white; line-height: 1.1; margin-bottom: 1.25rem; letter-spacing: -0.02em; }
  .hero-sub { font-size: 1.0625rem; line-height: 1.75; color: #94afc7; max-width: 600px; margin: 0 auto; }

  .contact-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) { .contact-grid { grid-template-columns: 2fr 3fr; } }

  .h2 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 800; color: var(--text-heading); margin-bottom: 1rem; }
  .text-center { text-align: center; margin-bottom: 0.5rem; }
  .center-sub { text-align: center; color: var(--text-muted); font-size: 1rem; margin-bottom: 2rem; }

  .contact-info { display: flex; flex-direction: column; gap: 1.5rem; }
  .info-item { display: flex; gap: 1rem; align-items: flex-start; }
  .info-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 0.125rem; }
  .info-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.25rem; }
  .info-value { font-size: 0.9375rem; font-weight: 600; color: var(--text-heading); margin: 0; }
  .info-sub { font-size: 0.8125rem; color: var(--text-muted); margin: 0.125rem 0 0; }
  .info-link { font-size: 0.9375rem; font-weight: 600; color: #FF6B35; text-decoration: none; }
  .info-link:hover { text-decoration: underline; }

  .social-section { border-top: 1px solid #f3f4f6; padding-top: 1.25rem; }
  .social-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 0.75rem; }
  .social-links { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .social-link { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; font-weight: 600; color: var(--text-heading); text-decoration: none; background: var(--surface-2); padding: 0.5rem 0.875rem; border-radius: 0.5rem; transition: background 0.15s, color 0.15s; }
  .social-link:hover { background: #1E3A5F; color: white; }

  .booking-card { background: var(--surface-2); border-radius: 1rem; padding: 1.5rem; border: 1px solid var(--border-strong); }
  .booking-h3 { font-size: 1rem; font-weight: 700; color: var(--text-heading); margin-bottom: 0.5rem; }
  .booking-p { font-size: 0.875rem; line-height: 1.65; color: var(--text-body); margin-bottom: 1rem; }
  .btn-outline { display: inline-block; background: transparent; color: var(--text-heading); font-weight: 700; padding: 0.625rem 1.25rem; border-radius: 0.5rem; text-decoration: none; font-size: 0.875rem; border: 2px solid var(--text-heading); transition: background 0.15s, color 0.15s; }
  .btn-outline:hover { background: #1E3A5F; color: white; }

  .form-sub { font-size: 0.9375rem; line-height: 1.65; color: var(--text-muted); margin-bottom: 1.5rem; }

  .quick-links { display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; }
  .quick-link { display: flex; align-items: center; gap: 0.5rem; background: var(--surface-card); border: 1px solid var(--border-strong); color: var(--text-heading); font-weight: 600; font-size: 0.9rem; padding: 0.625rem 1.25rem; border-radius: 0.5rem; text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s; }
  .quick-link:hover { border-color: #FF6B35; box-shadow: 0 2px 8px rgb(255 107 53 / 0.15); }
</style>

