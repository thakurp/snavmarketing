  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--bg);
  }

  /* Aurora orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    pointer-events: none;
    animation: drift 12s ease-in-out infinite alternate;
  }
  .orb-a {
    width: 700px; height: 700px;
    background: radial-gradient(circle, rgba(255,107,53,0.18) 0%, transparent 65%);
    top: -200px; right: -150px;
    animation-duration: 14s;
  }
  .orb-b {
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(129,140,248,0.14) 0%, transparent 65%);
    bottom: -150px; left: -100px;
    animation-duration: 11s;
    animation-direction: alternate-reverse;
  }
  .orb-c {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(30,58,95,0.5) 0%, transparent 65%);
    top: 30%; left: 30%;
    animation-duration: 16s;
  }
  @keyframes drift {
    0%   { transform: translate(0, 0) scale(1); }
    100% { transform: translate(30px, -20px) scale(1.05); }
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding-top: 120px;
    padding-bottom: 80px;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem 0.375rem 0.625rem;
    background: rgba(255,107,53,0.1);
    border: 1px solid rgba(255,107,53,0.25);
    border-radius: 999px;
