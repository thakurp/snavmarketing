---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Digital Marketing for Restaurants & Cafés &#8212; Sydney"
  description="SNAV Marketing helps Sydney restaurants and caf?s fill tables, boost bookings and build loyal repeat customers with Google, social media and targeted local advertising."
  canonical="/industries/restaurants"
>
  <section class="industry-hero">
    <div class="container-lg">
      <p class="eyebrow">Industry Specialists</p>
      <div class="hero-icon">🍽</div>
      <h1 class="hero-title">Fill Tables Every Night.<br />Build a Restaurant<br />People Love Online.</h1>
      <p class="hero-sub">
        Great food deserves a full dining room. SNAV helps Sydney restaurants and cafés build the digital presence that turns curious browsers into loyal diners &#8212; even on a quiet Tuesday.
      </p>
      <div class="hero-ctas">
        <a href="/contact" class="btn-primary">Fill My Restaurant</a>
        <a href="/portfolio" class="btn-secondary">See Our Results</a>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-lg two-col">
      <div>
        <h2 class="h2">Sydney's Restaurant Scene Is Competitive. Your Marketing Needs to Be Too.</h2>
        <p class="body-text">You've invested in the kitchen, the fit-out and the team. But if you're invisible on Google, your Insta is a ghost town and you're relying on walk-ins &#8212; you're leaving serious revenue on the table (no pun intended).</p>
        <p class="body-text">SNAV builds end-to-end digital marketing for Sydney restaurants &#8212; from mouthwatering social media content and Google Maps dominance, to targeted ads promoting your weekly specials and online reservation systems driven by real campaigns.</p>

        <h3 class="h3">What We Do for Restaurants</h3>
        <ul class="service-list">
          <li>Google Maps & local SEO &#8212; "restaurant near me" and "best [cuisine] Sydney"</li>
          <li>Google and Meta Ads targeting local diners</li>
          <li>Instagram and Facebook content &#8212; food photography, Reels, Stories</li>
          <li>Google review generation and management</li>
          <li>Online reservation integration (OpenTable, Resy, etc.)</li>
          <li>Weekly specials and event promotion campaigns</li>
          <li>Loyalty and repeat-visit email/SMS campaigns</li>
        </ul>
      </div>
      <div class="results-col">
        <h3 style="color:white; font-size:1.125rem; font-weight:700; margin-bottom:1.25rem;">Real Results</h3>
        <div class="result-card">
          <span class="result-stat">+180%</span>
          <span class="result-label">Midweek revenue increase</span>
          <span class="result-client">The Olive Press, Newtown</span>
        </div>
        <div class="result-card">
          <span class="result-stat">40+</span>
          <span class="result-label">New Google reviews per month</span>
          <span class="result-client">Saffron Kitchen, Surry Hills</span>
        </div>
        <div class="result-card">
          <span class="result-stat">3x</span>
          <span class="result-label">Online reservations increase</span>
          <span class="result-client">Harbour View Bistro, Pyrmont</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad" style="background: var(--bg-alt);">
    <div class="container-lg">
      <h2 class="h2 text-center">How We Fill Your Restaurant</h2>
      <div class="what-grid">
        <div class="what-card">
          <span class="what-icon">???</span>
          <h3>Google Maps Dominance</h3>
          <p>When someone searches "Italian restaurant Newtown" or "brunch near me", you appear in the top 3 results. We optimise your Google Business Profile and build local authority.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">??</span>
          <h3>Food Content That Sells</h3>
          <p>We help you create or capture content that makes mouths water on Instagram and Facebook &#8212; hero dish photos, chef stories, seasonal specials and dining room atmosphere shots.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">??</span>
          <h3>Targeted Local Ads</h3>
          <p>Reach food lovers in specific Sydney suburbs with dinner promos, weekend specials and event announcements. We target by location, time of day and interest &#8212; so you're not wasting budget.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">??</span>
          <h3>Fill the Dead Nights</h3>
          <p>Strategic promotions for Tuesday and Wednesday nights &#8212; specific offers, limited spots, creates urgency. We turn your quietest nights into profitable ones.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">?</span>
          <h3>Review Management</h3>
          <p>Automated follow-up with diners post-visit to generate 5-star reviews on Google. We also help you respond to negative reviews professionally to protect your reputation.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">??</span>
          <h3>Repeat Visit Campaigns</h3>
          <p>Email and SMS campaigns that bring your existing diners back &#8212; birthday promotions, seasonal menus, loyalty rewards and event announcements.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad cta-section">
    <div class="container-lg cta-inner">
      <div>
        <h2 class="cta-heading">Ready to Fill Your Dining Room?</h2>
        <p class="cta-sub">Get a free local search audit and social media review. We'll show you exactly where you're losing diners online and how we'd bring them back.</p>
        <ul class="cta-list">
          <li>? Sydney restaurant marketing specialists</li>
          <li>? Google + social + reservations &#8212; all working together</li>
          <li>&#10003; No lock-in contracts</li>
        </ul>
      </div>
      <div class="cta-form">
        <ContactForm />
      </div>
    </div>
  </section>
</Layout>

<style>
  .industry-hero { background: linear-gradient(135deg, #1E3A5F 0%, #152b47 100%); padding: 5rem 0; text-align: center; }
  .eyebrow { font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #FF6B35; margin-bottom: 1rem; }
  .hero-icon { font-size: 4rem; margin-bottom: 1rem; }
  .hero-title { font-size: clamp(2.25rem, 5vw, 3.25rem); font-weight: 900; color: white; line-height: 1.1; margin-bottom: 1.25rem; letter-spacing: -0.02em; }
  .hero-sub { font-size: 1.0625rem; line-height: 1.75; color: #94afc7; max-width: 600px; margin: 0 auto 2rem; }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }

  .two-col { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) { .two-col { grid-template-columns: 1fr 1fr; } }

  .h2 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 800; color: var(--text-heading); margin-bottom: 1rem; }
  .h3 { font-size: 1.125rem; font-weight: 700; color: var(--text-heading); margin: 1.5rem 0 0.75rem; }
  .body-text { font-size: 1rem; line-height: 1.8; color: var(--text-body); margin-bottom: 1rem; }
  .text-center { text-align: center; margin-bottom: 2.5rem; }

  .service-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.9375rem; color: var(--text-body); }
  .service-list li::before { content: '\2192 '; color: #FF6B35; font-weight: 700; }

  .results-col { background: #1E3A5F; border-radius: 1rem; padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .result-card { background: rgba(255,255,255,0.08); border-radius: 0.75rem; padding: 1.25rem 1.5rem; border: 1px solid rgba(255,255,255,0.1); }
  .result-stat { display: block; font-size: 2.5rem; font-weight: 900; color: #FF6B35; line-height: 1; }
  .result-label { display: block; font-size: 1rem; font-weight: 700; color: white; margin: 0.25rem 0; }
  .result-client { display: block; font-size: 0.8125rem; color: #7a9bbf; }

  .what-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 640px)  { .what-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .what-grid { grid-template-columns: repeat(3, 1fr); } }

  .what-card { background: var(--surface-card); border-radius: 0.75rem; padding: 1.5rem; box-shadow: 0 2px 16px rgb(0 0 0 / 0.06); border: 1px solid var(--border); }
  .what-icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
  .what-card h3 { font-size: 1rem; font-weight: 700; color: var(--text-heading); margin-bottom: 0.5rem; }
  .what-card p { font-size: 0.9rem; line-height: 1.65; color: var(--text-muted); }

  .cta-section { background: linear-gradient(135deg, #FF6B35 0%, #e55a24 100%); }
  .cta-inner { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start; }
  @media (min-width: 1024px) { .cta-inner { grid-template-columns: 1fr 1fr; } }
  .cta-heading { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: white; margin-bottom: 1rem; }
  .cta-sub { font-size: 1.0625rem; line-height: 1.75; color: rgba(255,255,255,0.85); margin-bottom: 1.5rem; }
  .cta-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem; font-size: 0.9375rem; font-weight: 600; color: white; }
  .cta-form { background: var(--surface-card); padding: 2rem; border-radius: 1rem; box-shadow: 0 16px 48px rgb(0 0 0 / 0.2); }
</style>

