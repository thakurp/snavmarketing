---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';

const trades = ['Electricians', 'Plumbers', 'Builders', 'Carpenters', 'Painters', 'HVAC / Air Conditioning', 'Tilers', 'Landscapers', 'Pest Control', 'Cleaners', 'Removalists', 'Roofers'];

const results = [
  { stat: '+340%', label: 'More leads', client: 'PowerUp Electrical, Parramatta' },
  { stat: '&#8211;3x', label: 'More quotes per week', client: 'Clear Flow Plumbing, Penrith' },
  { stat: '&#8211;60%', label: 'Cost per lead', client: 'BuildRight Construction, Blacktown' },
];
---

<Layout
  title="Digital Marketing for Tradies &#8212; Sydney"
  description="SNAV Marketing helps Sydney electricians, plumbers, builders and all tradies get more jobs. Google Ads, SEO, websites and lead generation built specifically for trade businesses."
  canonical="/industries/tradies"
>
  <section class="industry-hero">
    <div class="container-lg">
      <p class="eyebrow">Industry Specialists</p>
      <div class="hero-icon">🔧</div>
      <h1 class="hero-title">More Jobs for Sydney Tradies</h1>
      <p class="hero-sub">
        Your phone should be ringing with real local jobs &#8212; not tyre-kickers. SNAV builds digital marketing systems that get Sydney tradies fully booked without the time-wasting.
      </p>
      <div class="hero-ctas">
        <a href="/contact" class="btn-primary">Get More Tradie Jobs</a>
        <a href="/portfolio" class="btn-secondary">See Tradie Results</a>
      </div>
    </div>
  </section>

  <!-- Pain points -->
  <section class="section-pad">
    <div class="container-lg two-col">
      <div>
        <h2 class="h2">We Get It. Running a Trade Business Is Hard Work.</h2>
        <p class="body-text">You're good at the job. But getting consistent, quality enquiries is another skill set entirely &#8212; and most tradies don't have time to learn it.</p>
        <p class="body-text">Cheap directory listings, a mate who "does websites", boosting a random Facebook post &#8212; none of it works consistently. You end up chasing low-quality leads or relying entirely on word of mouth, which is great until it dries up.</p>
        <p class="body-text">SNAV builds you a proper digital marketing engine: one that runs 24/7, filters out the tyre-kickers, and sends real, local, high-value jobs straight to your phone.</p>

        <h3 class="h3">Trades We Work With</h3>
        <div class="trades-grid">
          {trades.map(t => <span class="trade-pill">{t}</span>)}
        </div>
      </div>
      <div class="results-col">
        <h3 class="h3" style="color:white;">Tradie Results</h3>
        {results.map(r => (
          <div class="result-card">
            <span class="result-stat">{r.stat}</span>
            <span class="result-label">{r.label}</span>
            <span class="result-client">{r.client}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What We Do for Tradies -->
  <section class="section-pad" style="background: var(--bg-alt);">
    <div class="container-lg">
      <h2 class="h2 text-center">What We Do for Tradies</h2>
      <div class="what-grid">
        <div class="what-card">
          <span class="what-icon">??</span>
          <h3>Google Ads &#8212; Emergency & Local Intent</h3>
          <p>When someone searches "emergency plumber near me" or "electrician Parramatta", your ad shows first. We target urgent, high-intent searches that convert into calls instantly.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">???</span>
          <h3>Google Maps & Local SEO</h3>
          <p>We optimise your Google Business Profile and build local citations so you appear in the Maps pack &#8212; the first thing people see when they search for your trade in their suburb.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">??</span>
          <h3>Tradie Websites That Convert</h3>
          <p>Fast, mobile-first trade websites with prominent phone numbers, before/after galleries and instant quote forms. Built to convert a browsing homeowner into a booked job.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">??</span>
          <h3>Facebook & Instagram Ads</h3>
          <p>Target homeowners in specific Sydney postcodes and suburbs with before/after project photos and seasonal promotions. Great for building awareness and quote requests.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">?</span>
          <h3>Review Generation</h3>
          <p>Automated follow-up systems that ask your satisfied customers for Google reviews &#8212; building the social proof that makes homeowners choose you over competitors.</p>
        </div>
        <div class="what-card">
          <span class="what-icon">?</span>
          <h3>Lead Qualification</h3>
          <p>Not all leads are equal. We help you filter out low-budget and out-of-area enquiries so you spend time quoting jobs you actually want to win.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-pad cta-section">
    <div class="container-lg cta-inner">
      <div>
        <h2 class="cta-heading">Ready to Fill Your Job Diary?</h2>
        <p class="cta-sub">Get a free digital audit of your online presence. We'll tell you exactly what's costing you jobs and what we'd do to fix it.</p>
        <ul class="cta-list">
          <li>? Sydney-based team who understand the tradie market</li>
          <li>? Results in weeks, not months</li>
          <li>&#10003; No lock-in contracts</li>
        </ul>
      </div>
      <div class="cta-form">
        <ContactForm />
      </div>
    </div>
  </section>
</Layout>

<style>
  .industry-hero { background: linear-gradient(135deg, #1E3A5F 0%, #152b47 100%); padding: 5rem 0; text-align: center; }
  .eyebrow { font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #FF6B35; margin-bottom: 1rem; }
  .hero-icon { font-size: 4rem; margin-bottom: 1rem; }
  .hero-title { font-size: clamp(2.25rem, 5vw, 3.5rem); font-weight: 900; color: white; line-height: 1.1; margin-bottom: 1.25rem; letter-spacing: -0.02em; }
  .hero-sub { font-size: 1.0625rem; line-height: 1.75; color: #94afc7; max-width: 600px; margin: 0 auto 2rem; }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }

  .two-col { display: grid; grid-template-columns: 1fr; gap: 3rem; }
  @media (min-width: 1024px) { .two-col { grid-template-columns: 1fr 1fr; } }

  .h2 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 800; color: var(--text-heading); margin-bottom: 1rem; }
  .h3 { font-size: 1.125rem; font-weight: 700; color: var(--text-heading); margin: 1.5rem 0 0.75rem; }
  .body-text { font-size: 1rem; line-height: 1.8; color: var(--text-body); margin-bottom: 1rem; }
  .text-center { text-align: center; margin-bottom: 2.5rem; }

  .trades-grid { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
  .trade-pill { background: var(--surface-2); color: var(--text-heading); font-size: 0.8125rem; font-weight: 600; padding: 0.375rem 0.875rem; border-radius: 9999px; border: 1.5px solid #d1d9e6; }

  .results-col { background: #1E3A5F; border-radius: 1rem; padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .result-card { background: rgba(255,255,255,0.08); border-radius: 0.75rem; padding: 1.25rem 1.5rem; border: 1px solid rgba(255,255,255,0.1); }
  .result-stat { display: block; font-size: 2.5rem; font-weight: 900; color: #FF6B35; line-height: 1; }
  .result-label { display: block; font-size: 1rem; font-weight: 700; color: white; margin: 0.25rem 0; }
  .result-client { display: block; font-size: 0.8125rem; color: #7a9bbf; }

  .what-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 640px)  { .what-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .what-grid { grid-template-columns: repeat(3, 1fr); } }

  .what-card { background: var(--surface-card); border-radius: 0.75rem; padding: 1.5rem; box-shadow: 0 2px 16px rgb(0 0 0 / 0.06); border: 1px solid var(--border); }
  .what-icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
  .what-card h3 { font-size: 1rem; font-weight: 700; color: var(--text-heading); margin-bottom: 0.5rem; }
  .what-card p { font-size: 0.9rem; line-height: 1.65; color: var(--text-muted); }

  .cta-section { background: linear-gradient(135deg, #FF6B35 0%, #e55a24 100%); }
  .cta-inner { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start; }
  @media (min-width: 1024px) { .cta-inner { grid-template-columns: 1fr 1fr; } }
  .cta-heading { font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 800; color: white; margin-bottom: 1rem; }
  .cta-sub { font-size: 1.0625rem; line-height: 1.75; color: rgba(255,255,255,0.85); margin-bottom: 1.5rem; }
  .cta-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem; font-size: 0.9375rem; font-weight: 600; color: white; }
  .cta-form { background: var(--surface-card); padding: 2rem; border-radius: 1rem; box-shadow: 0 16px 48px rgb(0 0 0 / 0.2); }
</style>


