---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';

const benefits = [
  { icon: '📱', title: 'Mobile-First Design', desc: 'Over 70% of your customers find you on their phone. Every site we build looks great and loads fast on any device.' },
  { icon: '⚡', title: 'Lightning Fast', desc: 'Slow sites lose customers. We build high-performance sites that score 90+ on Google PageSpeed &#8212; protecting your SEO and conversion rate.' },
  { icon: '🔒', title: 'Secure & Reliable', desc: 'SSL, secure hosting, regular backups and uptime monitoring. Your website is your 24/7 storefront &#8212; it can\'t go down.' },
  { icon: '🎯', title: 'Conversion Optimised', desc: 'Beautiful isn\'t enough. Every page is designed to guide visitors towards calling, booking or filling in your form.' },
  { icon: '🔍', title: 'SEO Ready', desc: 'Built with proper meta tags, structured data, fast loading and clean code &#8212; so Google can find and rank you from day one.' },
  { icon: '⚙', title: 'Easy to Update', desc: 'We deliver websites you can actually manage yourself with simple CMS tools &#8212; or we manage it for you. Your choice.' },
];
---

<Layout
  title="Website Creation Sydney &#8212; Custom Business Websites"
  description="SNAV Marketing builds fast, mobile-first, conversion-optimised websites for Sydney tradies, restaurants, barbers and SMEs. SEO-ready, professionally designed, delivered fast."
  canonical="/services/website-creation"
>
  <section class="service-hero">
    <div class="container-lg service-hero-inner">
      <a href="/services" class="breadcrumb">&#8592; All Services</a>
      <div class="service-icon-lg">🌐</div>
      <h1 class="service-title">Website Creation</h1>
      <p class="service-subtitle">Your website is your #1 salesperson. We build fast, beautiful, mobile-first sites that turn visitors into customers &#8212; 24/7.</p>
      <a href="/contact" class="btn-primary service-hero-cta">Get a Free Website Quote</a>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-lg service-layout">
      <div class="service-main">
        <h2 class="service-h2">A Website That Actually Works for Your Business</h2>
        <p class="service-body">A lot of SME websites look decent but don't convert. They're slow, unclear, or buried on page 6 of Google. SNAV builds websites engineered to rank, load fast and turn visitors into paying customers &#8212; not just pretty pages that sit there doing nothing.</p>
        <p class="service-body">From a 5-page brochure site for a tradie starting out, to a fully custom restaurant booking site or e-commerce store &#8212; we design and build it all. And because we also handle ads and SEO, your website is built from day one to work with your marketing, not against it.</p>

        <h3 class="service-h3">What We Build</h3>
        <ul class="service-list">
          <li>Business brochure sites (5&#8211;15 pages) &#8212; tradies, barbers, salons, consultants</li>
          <li>Restaurant / hospitality sites with menu, reservations and events</li>
          <li>E-commerce stores (Shopify, WooCommerce)</li>
          <li>Landing pages optimised for ad campaigns</li>
          <li>Booking and appointment systems</li>
          <li>Multi-location business sites</li>
        </ul>

        <h3 class="service-h3">Our Process</h3>
        <ul class="service-list">
          <li>Discovery call to understand your business, customers and goals</li>
          <li>Strategy and wireframe &#8212; structure before design</li>
          <li>Design mockups for your approval</li>
          <li>Development, testing and quality assurance</li>
          <li>SEO setup and Google Analytics / Search Console integration</li>
          <li>Launch and 30-day post-launch support</li>
        </ul>
      </div>
      <div class="service-sidebar">
        <div class="sidebar-card">
          <h3 class="sidebar-heading">Get a Website Quote</h3>
          <p class="sidebar-sub">Tell us about your business and we'll scope out what you need &#8212; free, no obligation.</p>
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <section class="section-pad" style="background: var(--bg-alt);">
    <div class="container-lg">
      <h2 class="benefits-heading">What Makes an SNAV Website Different</h2>
      <div class="benefits-grid">
        {benefits.map(b => (
          <div class="benefit-card">
            <span class="benefit-icon">{b.icon}</span>
            <h3 class="benefit-title">{b.title}</h3>
            <p class="benefit-desc">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .service-hero {
    background: linear-gradient(135deg, #1E3A5F 0%, #2a4f80 100%);
    padding: calc(4rem + 80px) 0 4.5rem;
    text-align: center;
  }
  .breadcrumb { font-size: 0.875rem; color: #7a9bbf; display: block; margin-bottom: 1.5rem; }
  .breadcrumb:hover { color: #FF6B35; }
  .service-icon-lg { font-size: 3.5rem; margin-bottom: 1rem; }
  .service-title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; color: white; margin-bottom: 1rem; }
  .service-subtitle { font-size: 1.0625rem; color: #94afc7; max-width: 540px; margin: 0 auto 2rem; line-height: 1.7; }
  .service-hero-cta { font-size: 1rem; padding: 0.875rem 2rem; }
  .service-layout { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start; }
  @media (min-width: 1024px) { .service-layout { grid-template-columns: 1fr 380px; } }
  .service-h2 { font-size: 1.75rem; font-weight: 800; color: var(--text-heading); margin-bottom: 1rem; }
  .service-h3 { font-size: 1.125rem; font-weight: 700; color: var(--text-heading); margin: 2rem 0 0.75rem; }
  .service-body { font-size: 1rem; line-height: 1.8; color: var(--text-body); margin-bottom: 1rem; }
  .service-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; font-size: 0.9375rem; color: var(--text-body); }
  .service-list li::before { content: '\2192 '; color: #FF6B35; font-weight: 700; }
  .sidebar-card { background: var(--bg-alt); border-radius: 0.75rem; padding: 1.75rem; border: 1px solid var(--border-strong); position: sticky; top: calc(80px + 1rem); }
  .sidebar-heading { font-size: 1.125rem; font-weight: 700; color: var(--text-heading); margin-bottom: 0.5rem; }
  .sidebar-sub { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1.25rem; line-height: 1.6; }
  .benefits-heading { font-size: clamp(1.5rem,3vw,2rem); font-weight: 800; color: var(--text-heading); text-align: center; margin-bottom: 2.5rem; }
  .benefits-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 640px)  { .benefits-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .benefits-grid { grid-template-columns: repeat(3, 1fr); } }
  .benefit-card { background: var(--surface-card); border-radius: 0.75rem; padding: 1.5rem; box-shadow: 0 2px 16px rgb(0 0 0 / 0.06); border: 1px solid var(--border); }
  .benefit-icon { font-size: 2rem; display: block; margin-bottom: 0.75rem; }
  .benefit-title { font-size: 1rem; font-weight: 700; color: var(--text-heading); margin-bottom: 0.5rem; }
  .benefit-desc { font-size: 0.9rem; line-height: 1.65; color: var(--text-muted); }
</style>


