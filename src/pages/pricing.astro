---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout
  title="Pricing &#8212; Digital Marketing Packages &#8212; SNAV Marketing"
  description="Transparent, affordable digital marketing pricing for Sydney small businesses. Starter from $499/mo, Growth $999/mo, or fully custom Scale packages. No lock-in contracts."
  canonical="/pricing"
>
  <!-- Hero -->
  <section class="pricing-hero">
    <div class="container-lg">
      <p class="eyebrow">Transparent Pricing</p>
      <h1 class="hero-title">Straightforward Pricing.<br />No Surprise Bills.</h1>
      <p class="hero-sub">All plans are month-to-month with no lock-in contracts. You get a dedicated account manager, monthly reporting and full ownership of all accounts and assets.</p>
    </div>
  </section>

  <!-- Plans -->
  <section class="section-pad">
    <div class="container-lg">
      <div class="plans-grid">
        <!-- Starter -->
        <div class="plan-card">
          <div class="plan-top">
            <p class="plan-name">Starter</p>
            <div class="plan-price-row">
              <span class="plan-price">$499</span>
              <span class="plan-period">/month</span>
            </div>
            <p class="plan-desc">Perfect for businesses just starting their digital marketing journey and looking to build a consistent online presence.</p>
            <a href="/contact" class="btn-plan-outline">Get Started</a>
          </div>
          <ul class="plan-features">
            <li class="feat feat-yes">1 digital marketing channel (Google or Social)</li>
            <li class="feat feat-yes">Google Business Profile management</li>
            <li class="feat feat-yes">Monthly performance report</li>
            <li class="feat feat-yes">Ad spend up to $1,000/mo included</li>
            <li class="feat feat-yes">Email and phone support</li>
            <li class="feat feat-no">Website creation or optimisation</li>
            <li class="feat feat-no">Multi-channel campaigns</li>
            <li class="feat feat-no">Custom landing pages</li>
            <li class="feat feat-no">Weekly reporting</li>
          </ul>
        </div>

        <!-- Growth (Most Popular) -->
        <div class="plan-card plan-highlight">
          <div class="plan-badge">Most Popular</div>
          <div class="plan-top">
            <p class="plan-name">Growth</p>
            <div class="plan-price-row">
              <span class="plan-price">$999</span>
              <span class="plan-period">/month</span>
            </div>
            <p class="plan-desc">For businesses ready to go multi-channel and turn digital marketing into a serious customer acquisition engine.</p>
            <a href="/contact" class="btn-plan-primary">Get Started</a>
          </div>
          <ul class="plan-features">
            <li class="feat feat-yes">Up to 3 channels (Google Ads + Meta + SEO)</li>
            <li class="feat feat-yes">Google Business Profile management</li>
            <li class="feat feat-yes">Weekly performance reporting</li>
            <li class="feat feat-yes">Ad spend up to $3,000/mo included</li>
            <li class="feat feat-yes">Email, phone and Slack support</li>
            <li class="feat feat-yes">1 custom landing page per quarter</li>
            <li class="feat feat-yes">Website optimisation (CRO)</li>
            <li class="feat feat-no">Full website creation</li>
            <li class="feat feat-no">App development</li>
          </ul>
        </div>

        <!-- Scale -->
        <div class="plan-card">
          <div class="plan-top">
            <p class="plan-name">Scale</p>
            <div class="plan-price-row">
              <span class="plan-price">Custom</span>
            </div>
            <p class="plan-desc">For established businesses and multi-location operators who want a full-service strategic partner with no limits.</p>
            <a href="/contact" class="btn-plan-outline">Talk to Us</a>
          </div>
          <ul class="plan-features">
            <li class="feat feat-yes">All channels &#8212; fully managed</li>
            <li class="feat feat-yes">Dedicated account strategist</li>
            <li class="feat feat-yes">Daily monitoring + real-time reporting</li>
            <li class="feat feat-yes">Unlimited ad spend management</li>
            <li class="feat feat-yes">Priority phone and email support</li>
            <li class="feat feat-yes">Custom landing pages &#8212; unlimited</li>
            <li class="feat feat-yes">Full website creation and maintenance</li>
            <li class="feat feat-yes">App development scoping</li>
            <li class="feat feat-yes">Quarterly strategy sessions</li>
          </ul>
        </div>
      </div>

      <p class="pricing-note">All prices exclude ad spend (media budget) paid directly to Google / Meta. Management fees as listed above. GST applicable for Australian businesses.</p>
    </div>
  </section>

  <!-- Add-Ons -->
  <section class="section-pad" style="background: var(--bg-alt);">
    <div class="container-lg">
      <h2 class="h2 text-center">Add-Ons</h2>
      <p class="text-center-sub">Need something specific? Add on any of these services to any plan.</p>
      <div class="addons-grid">
        <div class="addon-card">
          <p class="addon-name">Website Creation</p>
          <p class="addon-price">From $2,500</p>
          <p class="addon-desc">5-page conversion-optimised business website, custom design, mobile-first, fast loading.</p>
        </div>
        <div class="addon-card">
          <p class="addon-name">SEO Package</p>
          <p class="addon-price">From $399/mo</p>
          <p class="addon-desc">Technical SEO, local citations, content strategy and monthly reporting.</p>
        </div>
        <div class="addon-card">
          <p class="addon-name">Social Media Management</p>
          <p class="addon-price">From $299/mo</p>
          <p class="addon-desc">12 posts/month across 2 platforms, community management, hashtag strategy.</p>
        </div>
        <div class="addon-card">
          <p class="addon-name">App Development</p>
          <p class="addon-price">From $8,000</p>
          <p class="addon-desc">Custom mobile app (iOS + Android) &#8212; booking systems, loyalty programs, customer portals.</p>
        </div>
        <div class="addon-card">
          <p class="addon-name">Landing Page Build</p>
          <p class="addon-price">From $750</p>
          <p class="addon-desc">Dedicated campaign landing page designed to convert paid traffic into enquiries.</p>
        </div>
        <div class="addon-card">
          <p class="addon-name">Email Marketing Setup</p>
          <p class="addon-price">From $499</p>
          <p class="addon-desc">Email list setup, welcome sequence, monthly newsletters and automation flows.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-pad">
    <div class="container-lg faq-container">
      <h2 class="h2 text-center">Frequently Asked Questions</h2>
      <div class="faqs">
        <details class="faq-item">
          <summary class="faq-q">Do I need to sign a long-term contract?</summary>
          <div class="faq-a">No. All our plans are month-to-month with 30 days' notice to cancel. We believe in earning your business every month with results, not locking you in.</div>
        </details>
        <details class="faq-item">
          <summary class="faq-q">What does "ad spend included" mean?</summary>
          <div class="faq-a">The management fee covers our time and strategy work. The ad spend budget listed (e.g. $1,000/mo for Starter) is managed directly in your Google Ads or Meta Ads account &#8212; you pay Google/Meta directly, not us. This ensures 100% transparency on where your budget goes.</div>
        </details>
        <details class="faq-item">
          <summary class="faq-q">What if I want more ad spend than the plan includes?</summary>
          <div class="faq-a">No problem. Plans include management at the stated spend level. If you want to scale your ad budget above that, we simply move you to the next tier or add a small management uplift. We'll always discuss this with you first.</div>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Who owns the accounts, content and data?</summary>
          <div class="faq-a">You do. Always. We work inside your Google Ads, Meta Business Suite and other accounts. If we ever part ways, you keep everything &#8212; no asset hostage situations.</div>
        </details>
        <details class="faq-item">
          <summary class="faq-q">How long until I see results?</summary>
          <div class="faq-a">Paid ads (Google Ads, Meta) typically show initial results within 2&#8211;4 weeks as we test and optimise campaigns. SEO is a longer game &#8212; expect meaningful movement in 3&#8211;6 months. We'll be upfront about realistic timelines for your specific situation from day one.</div>
        </details>
        <details class="faq-item">
          <summary class="faq-q">Do you work with businesses outside Sydney?</summary>
          <div class="faq-a">Our focus is Sydney metro, but we do take on select clients across NSW and ACT. Our deep local market knowledge benefits businesses based in or targeting Sydney. Reach out and we'll let you know if we're the right fit.</div>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA with form -->
  <section class="section-pad cta-section">
    <div class="container-lg cta-inner">
      <div>
        <h2 class="cta-heading">Not Sure Which Plan Is Right for You?</h2>
        <p class="cta-sub">Tell us about your business and goals. We'll recommend the right starting point and build a custom plan that fits your budget.</p>
        <ul class="cta-list">
          <li>&#10003; Free 30-minute discovery call</li>
          <li>&#10003; No obligation, no hard sell</li>
          <li>&#10003; Custom recommendation within 24 hours</li>
        </ul>
      </div>
      <div class="cta-form">
        <ContactForm />
      </div>
    </div>
  </section>
</Layout>

<style>
  .pricing-hero { background: linear-gradient(135deg, #1E3A5F 0%, #152b47 100%); padding: calc(5rem + 80px) 0; text-align: center; }
  .eyebrow { font-size: 0.8125rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #FF6B35; margin-bottom: 1rem; }
  .hero-title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 900; color: white; line-height: 1.1; margin-bottom: 1.25rem; letter-spacing: -0.02em; }
  .hero-sub { font-size: 1.0625rem; line-height: 1.75; color: #94afc7; max-width: 600px; margin: 0 auto; }

  .plans-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; align-items: start; }
  @media (min-width: 1024px) { .plans-grid { grid-template-columns: repeat(3, 1fr); } }

  .plan-card { background: var(--surface-card); border-radius: 1rem; padding: 2rem; box-shadow: 0 4px 24px rgb(0 0 0 / 0.07); border: 2px solid var(--border); position: relative; }
  .plan-highlight { border-color: #FF6B35; }
  .plan-badge { position: absolute; top: -0.75rem; left: 50%; transform: translateX(-50%); background: #FF6B35; color: white; font-size: 0.75rem; font-weight: 800; padding: 0.25rem 1rem; border-radius: 999px; white-space: nowrap; text-transform: uppercase; letter-spacing: 0.05em; }
  .plan-top { margin-bottom: 1.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .plan-name { font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #FF6B35; margin-bottom: 0.5rem; }
  .plan-price-row { display: flex; align-items: baseline; gap: 0.25rem; margin-bottom: 0.75rem; }
  .plan-price { font-size: 2.5rem; font-weight: 900; color: var(--text-heading); line-height: 1; }
  .plan-period { font-size: 1rem; color: var(--text-muted); font-weight: 500; }
  .plan-desc { font-size: 0.9rem; line-height: 1.65; color: var(--text-muted); margin-bottom: 1.25rem; }

  .btn-plan-primary { display: block; text-align: center; background: #FF6B35; color: white; font-weight: 700; padding: 0.75rem 1.5rem; border-radius: 0.5rem; text-decoration: none; font-size: 0.9375rem; transition: background 0.15s, transform 0.15s; }
  .btn-plan-primary:hover { background: color-mix(in srgb, var(--accent) 85%, black); transform: translateY(-1px); }
  .btn-plan-outline { display: block; text-align: center; background: transparent; color: var(--text-heading); font-weight: 700; padding: 0.75rem 1.5rem; border-radius: 0.5rem; text-decoration: none; font-size: 0.9375rem; border: 2px solid var(--text-heading); transition: background 0.15s, color 0.15s; }
  .btn-plan-outline:hover { background: #1E3A5F; color: white; }

  .plan-features { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem; }
  .feat { font-size: 0.9rem; line-height: 1.5; padding-left: 1.5rem; position: relative; }
  .feat::before { position: absolute; left: 0; font-size: 0.875rem; font-weight: 700; }
  .feat-yes::before { content: '?'; color: #22c55e; }
  .feat-no::before { content: '?'; color: #d1d5db; }
  .feat-no { color: var(--text-muted); }

  .pricing-note { margin-top: 2rem; text-align: center; font-size: 0.875rem; color: var(--text-muted); }

  .h2 { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 800; color: var(--text-heading); margin-bottom: 0.75rem; }
  .text-center { text-align: center; margin-bottom: 0.5rem; }
  .text-center-sub { text-align: center; color: var(--text-muted); font-size: 1rem; margin-bottom: 2rem; }

  .addons-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 640px)  { .addons-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .addons-grid { grid-template-columns: repeat(3, 1fr); } }
  .addon-card { background: var(--surface-card); border-radius: 0.75rem; padding: 1.25rem 1.5rem; border: 1px solid var(--border-strong); }
  .addon-name { font-weight: 700; color: var(--text-heading); font-size: 0.9375rem; margin-bottom: 0.25rem; }
  .addon-price { font-weight: 800; color: #FF6B35; font-size: 1.125rem; margin-bottom: 0.5rem; }
  .addon-desc { font-size: 0.875rem; line-height: 1.6; color: var(--text-muted); margin: 0; }

  .faq-container { max-width: 760px; margin: 0 auto; }
  .faqs { display: flex; flex-direction: column; gap: 0.75rem; }
  .faq-item { border: 1px solid var(--border-strong); border-radius: 0.75rem; overflow: hidden; }
  .faq-q { cursor: pointer; padding: 1.125rem 1.25rem; font-weight: 700; font-size: 0.9375rem; color: var(--text-heading); list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-q::after { content: '+'; font-size: 1.25rem; color: #FF6B35; flex-shrink: 0; margin-left: 1rem; }
  .faq-item[open] > .faq-q::after { content: '-'; }
  .faq-a { padding: 0 1.25rem 1.125rem; font-size: 0.9rem; line-height: 1.75; color: var(--text-body); }

  .cta-section { background: linear-gradient(135deg, #1E3A5F 0%, #152b47 100%); }
  .cta-inner { display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: start; }
  @media (min-width: 1024px) { .cta-inner { grid-template-columns: 1fr 1fr; } }
  .cta-heading { font-size: clamp(1.75rem, 4vw, 2.25rem); font-weight: 800; color: white; margin-bottom: 1rem; }
  .cta-sub { font-size: 1.0625rem; line-height: 1.75; color: #94afc7; margin-bottom: 1.5rem; }
  .cta-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.625rem; font-size: 0.9375rem; font-weight: 600; color: #FF6B35; }
  .cta-form { background: var(--surface-card); padding: 2rem; border-radius: 1rem; box-shadow: 0 16px 48px rgb(0 0 0 / 0.3); }
</style>
